{
  "expo": {
    "name": "Universal Leaf Attendance",
    "slug": "universal-leaf-attendance",
    "owner": "unileaf",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ulattendance",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required for face verification attendance.",
        "NSLocationWhenInUseUsageDescription": "Location access is required for geotagged attendance."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.unileaf.employeeattendance"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "28b70400-a43e-4a99-b3c4-b8bbb5fdc35d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/28b70400-a43e-4a99-b3c4-b8bbb5fdc35d"
    }
  }
}
